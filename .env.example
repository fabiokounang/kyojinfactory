PORT=3000
NODE_ENV=development
JWT_SECRET=super-secret-key
SESSION_SECRET=session-secret-key
# If DATABASE_URL (mysql://...) is set, app uses MySQL.
# If empty, app uses local SQLite.
DATABASE_URL=
MYSQL_SSL=false
# Optional explicit MySQL config (if DATABASE_URL not used):
# DB_CLIENT=mysql
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=
# MYSQL_DATABASE=kyojinfactory
