<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <div class="bg-grid"></div>
    <main class="page">
      <header class="header">
        <div>
          <p class="eyebrow">Bill Of Materials</p>
          <h1>BOM Structure</h1>
          <p class="muted">Operator: <strong><%= user.username %></strong></p>
        </div>
        <form method="post" action="/logout">
          <button type="submit" class="btn-secondary">Logout</button>
        </form>
      </header>

      <section class="card">
        <div class="nav-links">
          <% (navItems || []).forEach((nav) => { %>
          <a href="<%= nav.path %>" class="nav-link <%= nav.active ? "active" : "" %>"><%= nav.label %></a>
          <% }) %>
        </div>
      </section>

      <section class="card">
        <div class="card-toolbar">
          <h2>Input BOM Structure</h2>
          <button type="button" class="js-open-create-bom">+ Tambah BOM</button>
        </div>
        <% if (msg) { %>
        <div class="alert info"><%= msg %></div>
        <% } %>
        <% if (error) { %>
        <div class="alert"><%= error %></div>
        <% } %>

        <div class="section-divider"></div>

        <div class="inline-upload">
          <div>
            <h3>Upload Excel BOM</h3>
            <p class="muted">Kolom kunci: FG CODE, LEVEL, PARENT CODE, COMPONENT CODE, COMPONENT NAME, QTY PER PARENT, UNIT, LENGTH (M), WASTE %, RAW MATERIAL CODE</p>
          </div>
          <form method="post" action="/bom-structure/import" enctype="multipart/form-data" class="upload-form">
            <input type="file" name="excelFileBom" accept=".xlsx,.xls" required />
            <button type="submit">Upload BOM</button>
          </form>
        </div>
      </section>

      <section class="card">
        <form method="get" action="/bom-structure" id="bomFilterForm" class="search-row datatable-filters">
          <input name="q" value="<%= typeof q !== 'undefined' ? q : '' %>" placeholder="Cari FG / parent / component / nama / RM…" />
          <input name="fgCode" value="<%= typeof fgCode !== 'undefined' ? fgCode : '' %>" placeholder="FG Code (exact)" />
          <select name="parentCode">
            <option value="">Filter Parent: Semua</option>
            <% parentOptions.forEach((parent) => { %>
            <option value="<%= parent.code %>" <%= parentFilter === parent.code ? "selected" : "" %>>
              <%= parent.label %>
            </option>
            <% }) %>
          </select>
          <select name="level">
            <option value="">Filter Level: Semua</option>
            <option value="1" <%= levelFilter === "1" ? "selected" : "" %>>Level 1</option>
            <option value="2" <%= levelFilter === "2" ? "selected" : "" %>>Level 2</option>
            <option value="3" <%= levelFilter === "3" ? "selected" : "" %>>Level 3</option>
            <option value="4" <%= levelFilter === "4" ? "selected" : "" %>>Level 4</option>
            <option value="5" <%= levelFilter === "5" ? "selected" : "" %>>Level 5</option>
          </select>
          <button type="submit">Filter</button>
          <a href="/bom-structure" class="nav-link">Reset</a>
        </form>

        <%- include('partials/pagination', { pagination, formId: 'bomFilterForm' }) %>

        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>FG Code</th>
                <th>Level</th>
                <th>Parent Code</th>
                <th>Component Code</th>
                <th>Component Name</th>
                <th>Qty Per Parent</th>
                <th>Unit</th>
                <th>Length (m)</th>
                <th>Waste %</th>
                <th>Raw Material Code</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              <% if (!rows.length) { %>
              <tr>
                <td colspan="11" class="empty">Belum ada struktur BOM untuk FG ini</td>
              </tr>
              <% } %>
              <% rows.forEach((row) => { %>
              <tr>
                <td><%= row.fgCode %></td>
                <td><%= row.level %></td>
                <td><%= row.parentCode %></td>
                <td><%= row.componentCode %></td>
                <td><%= row.componentName %></td>
                <td><%= row.qtyPerParent %></td>
                <td><%= row.unit %></td>
                <td><%= row.lengthM %></td>
                <td><%= row.wastePct %></td>
                <td><%= row.rawMaterialCode %></td>
                <td class="action-cell">
                  <button
                    type="button"
                    class="btn-secondary js-edit-bom"
                    data-id="<%= row.id %>"
                    data-fg-code="<%= row.fgCode %>"
                    data-parent-code="<%= row.parentCode %>"
                    data-component-code="<%= row.componentCode %>"
                    data-component-name="<%= row.componentName %>"
                    data-qty-per-parent="<%= row.qtyPerParent %>"
                    data-unit="<%= row.unit %>"
                    data-length-m="<%= row.lengthM %>"
                    data-waste-pct="<%= row.wastePct %>"
                    data-raw-material-code="<%= row.rawMaterialCode %>"
                  >
                    Edit
                  </button>
                  <button
                    type="button"
                    class="btn-danger js-open-delete"
                    data-action="/bom-structure/<%= row.id %>/delete"
                    data-label="BOM <%= row.componentCode %>"
                  >
                    Hapus
                  </button>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </section>
    </main>

    <dialog id="bomCreateModal" class="modal">
      <form method="dialog" class="modal-backdrop">
        <button class="modal-close-x" aria-label="Close">x</button>
      </form>
      <div class="modal-content">
        <h3>Tambah BOM Row</h3>
        <form method="post" action="/bom-structure" class="grid-5">
          <label>
            Parent Code
            <select name="parentRef" required>
              <% parentOptions.forEach((parent) => { %>
              <option value="<%= parent.ref %>" data-level="<%= parent.level %>">
                <%= parent.label %>
              </option>
              <% }) %>
            </select>
          </label>
          <input name="componentCode" placeholder="Component Code" required />
          <input name="componentName" placeholder="Component Name (optional)" />
          <input name="qtyPerParent" type="number" step="any" placeholder="Qty Per Parent" />
          <input name="unit" placeholder="Unit" />
          <input name="lengthM" type="number" step="any" placeholder="Length (m)" />
          <input name="wastePct" type="number" step="any" placeholder="Waste %" />
          <input name="rawMaterialCode" placeholder="Raw Material Code" />
          <button type="submit">Simpan BOM</button>
          <button type="button" class="btn-secondary js-close-create-bom">Batal</button>
        </form>
      </div>
    </dialog>

    <dialog id="bomEditModal" class="modal">
      <form method="dialog" class="modal-backdrop">
        <button class="modal-close-x" aria-label="Close">x</button>
      </form>
      <div class="modal-content">
        <h3>Edit BOM Row</h3>
        <form id="bomEditForm" method="post" class="grid-5">
          <input name="fgCode" id="edit-bom-fgCode" placeholder="FG Code" required />
          <input name="parentCode" id="edit-bom-parentCode" placeholder="Parent Code" required />
          <input name="componentCode" id="edit-bom-componentCode" placeholder="Component Code" required />
          <input name="componentName" id="edit-bom-componentName" placeholder="Component Name (optional)" />
          <input name="qtyPerParent" id="edit-bom-qtyPerParent" type="number" step="any" placeholder="Qty Per Parent" />
          <input name="unit" id="edit-bom-unit" placeholder="Unit" />
          <input name="lengthM" id="edit-bom-lengthM" type="number" step="any" placeholder="Length (m)" />
          <input name="wastePct" id="edit-bom-wastePct" type="number" step="any" placeholder="Waste %" />
          <input name="rawMaterialCode" id="edit-bom-rawMaterialCode" placeholder="Raw Material Code" />
          <button type="submit">Update BOM</button>
          <button type="button" class="btn-secondary js-close-bom-modal">Batal</button>
        </form>
      </div>
    </dialog>

    <dialog id="deleteWarnModal" class="modal">
      <form method="dialog" class="modal-backdrop">
        <button class="modal-close-x" aria-label="Close">x</button>
      </form>
      <div class="modal-content compact">
        <h3>Konfirmasi Hapus</h3>
        <p id="deleteWarnText" class="muted">Yakin ingin menghapus data ini?</p>
        <form id="deleteWarnForm" method="post" class="modal-actions">
          <button type="submit" class="btn-danger">Ya, Hapus</button>
          <button type="button" class="btn-secondary js-close-delete-modal">Batal</button>
        </form>
      </div>
    </dialog>

    <script src="/app-ui.js"></script>
  </body>
</html>
